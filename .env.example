# Tax Billing Application Environment Variables
# Copy this file to .env and update the values.
# The real .env is gitignored — never commit it.

# ---------------------------------------------------------------------------
# PostgreSQL container credentials
# ---------------------------------------------------------------------------
# Used by the postgres container (docker-compose.yml) to initialize the
# database on first boot. The backend also connects with these values via
# DATABASE_URL below — if you change POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB
# you MUST update DATABASE_URL to match.
POSTGRES_USER=tax_billing_user

# Generate a strong password with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me-run-the-command-below

# Database name; keep stable across environments so backups/restores line up.
POSTGRES_DB=tax_billing

# ---------------------------------------------------------------------------
# Backend DATABASE_URL
# ---------------------------------------------------------------------------
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
# GOTCHA: docker-compose does NOT expand variables inside values sourced from
# .env, so write the literal URL here with your real values — do not try to
# reference ${POSTGRES_USER} etc. from this file. The host is `db` because
# that is the service name on the internal compose network.
# Example (replace user/password/db with your actual values):
#   postgresql+asyncpg://tax_billing_user:your-generated-password@db:5432/tax_billing
DATABASE_URL=postgresql+asyncpg://tax_billing_user:change-me-run-the-command-below@db:5432/tax_billing

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# IMPORTANT: Generate a secure random key — never ship the placeholder.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-this-secret-in-production

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Debug mode (set to false in production)
DEBUG=true

# API URL for frontend
API_URL=http://localhost:8000
